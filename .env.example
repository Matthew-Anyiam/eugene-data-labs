# SEC User-Agent (required for SEC API)
SEC_USER_AGENT="YourApp/1.0 (contact: you@example.com)"

# Optional API keys
FRED_API_KEY=your_fred_api_key
FMP_API_KEY=your_fmp_api_key

# API authentication (comma-separated list of valid keys, empty = open)
EUGENE_API_KEYS=

# JWT secret for user authentication (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-in-production

# CORS origins (comma-separated, or * for all)
CORS_ORIGINS=*

# Database URL (default: SQLite in ./eugene_data.db)
# For Postgres: postgresql://user:pass@host:5432/eugene
DATABASE_URL=sqlite:///eugene_data.db

# Environment: development | staging | production
EUGENE_ENV=development

# Log level
LOG_LEVEL=INFO

# Server port
PORT=8000
